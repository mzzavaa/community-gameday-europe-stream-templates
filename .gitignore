# Screenshots — only readme-* files in subfolders are tracked; root-level debug captures are ignored
screenshots/*
!screenshots/compositions/
!screenshots/inserts/
!screenshots/studio/
!screenshots/misc/
screenshots/compositions/*
!screenshots/compositions/readme-*.png
!screenshots/compositions/README.md
screenshots/inserts/*
!screenshots/inserts/readme-*.png
!screenshots/inserts/README.md
screenshots/studio/*
!screenshots/studio/readme-*.png
!screenshots/studio/README.md
screenshots/misc/*
!screenshots/misc/readme-*.png
!screenshots/misc/README.md

# Video files — render locally, never commit
*.mp4
*.MP4
*.mov
*.MOV

# Tool/IDE state — never commit
.claude
.playwright-mcp/
